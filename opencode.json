{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ".opencode/plugins/graphify.js"
  ],
  "mcp": {
    "godot": {
      "type": "local",
      "command": ["npx", "-y", "godot-mcp-runtime"],
      "enabled": true,
      "environment": {
        "GODOT_PATH": "/usr/bin/godot"
      }
    }
  }
}