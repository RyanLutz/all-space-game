[ext_resource type="Shader" path="res://core/stars/star_corona.gdshader" id="3_corona"]

; ─── Mesh resources — placeholder sizes; StarMesh.gd duplicates and overwrites.
[sub_resource type="SphereMesh" id="SphereMesh_core"]
