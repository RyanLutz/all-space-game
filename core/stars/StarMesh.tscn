height = 2.20
radial_segments = 48
rings = 32

[sub_resource type="QuadMesh" id="QuadMesh_corona"]
size = Vector2(1, 1)

; ─── Shader materials — defaults match shader uniforms; StarMesh.gd duplicates and overrides per spawn.
[sub_resource type="ShaderMaterial" id="SurfMat_core"]
